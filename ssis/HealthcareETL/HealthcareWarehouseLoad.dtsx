    <DTS:Executable
      DTS:refId="Package\Load FactAdmission"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B33EE43F-C629-405B-AC84-0C29401DCB42}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FactAdmission"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{CDBFAFBF-ECBA-46E5-A14A-9676174DD6B8}"
          SQLTask:SqlStatementSource="INSERT INTO [HealthcareDW].[HealthcareDW].[FactAdmission] (&#xA;    [DateKey],&#xA;    [DischargeDateKey],&#xA;    [PatientKey],&#xA;    [DoctorKey],&#xA;    [HospitalKey],&#xA;    [InsuranceKey],&#xA;    [MedicationKey],&#xA;    [AdmissionTypeKey],&#xA;    [ConditionKey],&#xA;    [TestResultKey],&#xA;    [BillingAmount],&#xA;    [LengthOfStay]&#xA;)&#xA;SELECT&#xA;    ISNULL(dd1.[DateKey], -1)         AS DateKey,&#xA;    ISNULL(dd2.[DateKey], -1)         AS DischargeDateKey,&#xA;    ISNULL(dp.[PatientKey], -1)       AS PatientKey,&#xA;    ISNULL(doc.[DoctorKey], -1)       AS DoctorKey,&#xA;    ISNULL(h.[HospitalKey], -1)       AS HospitalKey,&#xA;    ISNULL(ins.[InsuranceKey], -1)    AS InsuranceKey,&#xA;    ISNULL(med.[MedicationKey], -1)   AS MedicationKey,&#xA;    ISNULL(adt.[AdmissionTypeKey],-1) AS AdmissionTypeKey,&#xA;    ISNULL(mc.[ConditionKey], -1)     AS ConditionKey,&#xA;    ISNULL(tr.[TestResultKey], -1)    AS TestResultKey,&#xA;    TRY_CAST(o.[Billing_Amount] AS DECIMAL(12,2)) AS BillingAmount,&#xA;    DATEDIFF(DAY, o.[Date_of_Admission], o.[Discharge_Date]) AS LengthOfStay&#xA;FROM [Healthcare_Staging].[dbo].[operation_source_clean] o&#xA;INNER JOIN [Healthcare_Staging].[dbo].[patient_source] p&#xA;    ON o.[source_id] = p.[source_id]&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimDate] dd1&#xA;    ON dd1.[FullDate] = o.[Date_of_Admission]&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimDate] dd2&#xA;    ON dd2.[FullDate] = o.[Discharge_Date]&#xA;LEFT JOIN (&#xA;    SELECT&#xA;        PatientKey, PatientName, Gender, BloodType, Age,&#xA;        ROW_NUMBER() OVER (&#xA;            PARTITION BY PatientName, Gender, BloodType, Age&#xA;            ORDER BY PatientKey&#xA;        ) AS rn&#xA;    FROM [HealthcareDW].[HealthcareDW].[DimPatient]&#xA;    WHERE PatientKey &lt;&gt; -1&#xA;) dp&#xA;    ON  dp.PatientName = UPPER(LTRIM(RTRIM(p.[Name])))&#xA;    AND dp.Gender      = UPPER(LTRIM(RTRIM(p.[Gender])))&#xA;    AND dp.BloodType   = UPPER(LTRIM(RTRIM(p.[Blood_Type])))&#xA;    AND dp.Age         = p.[Age]&#xA;    AND dp.rn = 1&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimDoctor] doc&#xA;    ON doc.[DoctorName] = UPPER(LTRIM(RTRIM(o.[Doctor])))&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimHospital] h&#xA;    ON h.[HospitalName] = UPPER(LTRIM(RTRIM(o.[Hospital])))&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimInsurance] ins&#xA;    ON ins.[InsuranceProvider] = UPPER(LTRIM(RTRIM(o.[Insurance_Provider])))&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimMedication] med&#xA;    ON med.[MedicationName] = UPPER(LTRIM(RTRIM(o.[Medication])))&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimAdmissionType] adt&#xA;    ON adt.[AdmissionTypeName] = UPPER(LTRIM(RTRIM(o.[Admission_Type])))&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimMedicalCondition] mc&#xA;    ON mc.[ConditionName] = UPPER(LTRIM(RTRIM(o.[Medical_Condition])))&#xA;LEFT JOIN [HealthcareDW].[HealthcareDW].[DimTestResult] tr&#xA;    ON tr.[TestResultName] = UPPER(LTRIM(RTRIM(o.[Test_Results])));" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load FactMonthlySummary"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6CF3503F-00E1-44AE-8106-7E467009D5D8}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FactMonthlySummary"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{CDBFAFBF-ECBA-46E5-A14A-9676174DD6B8}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE [HealthcareDW].[HealthcareDW].[FactMonthlyHospitalSummary];&#xA;&#xA;;WITH MonthlyData AS (&#xA;    SELECT&#xA;        CAST(&#xA;            CAST(d.[Year] AS VARCHAR(4))&#xA;            + RIGHT('0' + CAST(d.[Month] AS VARCHAR(2)), 2)&#xA;            + '01'&#xA;        AS INT) AS [MonthKey],&#xA;        f.[HospitalKey],&#xA;        COUNT(*) AS [TotalAdmissions],&#xA;        SUM(f.[BillingAmount]) AS [TotalBilling],&#xA;        AVG(f.[BillingAmount]) AS [AvgBilling],&#xA;        AVG(CAST(f.[LengthOfStay] AS DECIMAL(5,2))) AS [AvgLengthOfStay],&#xA;        SUM(CASE WHEN adt.[AdmissionTypeName] = 'EMERGENCY' THEN 1 ELSE 0 END) AS [EmergencyCount],&#xA;        SUM(CASE WHEN tr.[TestResultName] = 'ABNORMAL' THEN 1 ELSE 0 END) AS [AbnormalTestCount]&#xA;    FROM [HealthcareDW].[HealthcareDW].[FactAdmission] f&#xA;    INNER JOIN [HealthcareDW].[HealthcareDW].[DimDate] d&#xA;        ON f.[DateKey] = d.[DateKey]&#xA;    LEFT JOIN [HealthcareDW].[HealthcareDW].[DimAdmissionType] adt&#xA;        ON f.[AdmissionTypeKey] = adt.[AdmissionTypeKey]&#xA;    LEFT JOIN [HealthcareDW].[HealthcareDW].[DimTestResult] tr&#xA;        ON f.[TestResultKey] = tr.[TestResultKey]&#xA;    WHERE f.[DateKey] &lt;&gt; -1&#xA;      AND f.[HospitalKey] &lt;&gt; -1&#xA;    GROUP BY&#xA;        CAST(&#xA;            CAST(d.[Year] AS VARCHAR(4))&#xA;            + RIGHT('0' + CAST(d.[Month] AS VARCHAR(2)), 2)&#xA;            + '01'&#xA;        AS INT),&#xA;        f.[HospitalKey]&#xA;)&#xA;INSERT INTO [HealthcareDW].[HealthcareDW].[FactMonthlyHospitalSummary] (&#xA;    [MonthKey],&#xA;    [HospitalKey],&#xA;    [TotalAdmissions],&#xA;    [TotalBilling],&#xA;    [AvgBilling],&#xA;    [AvgLengthOfStay],&#xA;    [EmergencyCount],&#xA;    [AbnormalTestCount]&#xA;)&#xA;SELECT&#xA;    [MonthKey],&#xA;    [HospitalKey],&#xA;    [TotalAdmissions],&#xA;    [TotalBilling],&#xA;    [AvgBilling],&#xA;    [AvgLengthOfStay],&#xA;    [EmergencyCount],&#xA;    [AbnormalTestCount]&#xA;FROM MonthlyData;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log end"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{E4CC7756-8597-4AC4-BC9C-25CB4A309C9E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log end"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{CDBFAFBF-ECBA-46E5-A14A-9676174DD6B8}"
          SQLTask:SqlStatementSource="UPDATE HealthcareDW.dbo.ETL_LOG&#xA;SET EndTime = GETDATE(),&#xA;    Status = 'Success',&#xA;    RowsLoaded = (SELECT COUNT(*) FROM [HealthcareDW].[FactAdmission]),&#xA;    RowsTransformed = (SELECT COUNT(*) FROM [HealthcareDW].[FactMonthlyHospitalSummary])&#xA;WHERE RunID = (&#xA;    SELECT MAX(RunID)&#xA;    FROM HealthcareDW.dbo.ETL_LOG&#xA;    WHERE TableName = 'ETL Initial Load'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log start"
