      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{CDBFAFBF-ECBA-46E5-A14A-9676174DD6B8}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE [HealthcareDW].[FactMonthlyHospitalSummary];&#xA;TRUNCATE TABLE [HealthcareDW].[FactAdmission];&#xA;&#xA;DELETE FROM [HealthcareDW].[DimPatient] WHERE PatientKey != -1;&#xA;DELETE FROM [HealthcareDW].[DimDoctor] WHERE DoctorKey != -1;&#xA;DELETE FROM [HealthcareDW].[DimHospital] WHERE HospitalKey != -1;&#xA;DELETE FROM [HealthcareDW].[DimInsurance] WHERE InsuranceKey != -1;&#xA;DELETE FROM [HealthcareDW].[DimMedication] WHERE MedicationKey != -1;&#xA;DELETE FROM [HealthcareDW].[DimDate] WHERE DateKey != -1;&#xA;&#xA;-- Nếu DW mới có 3 dim này thì thêm:&#xA;DELETE FROM [HealthcareDW].[DimAdmissionType] WHERE AdmissionTypeKey != -1;&#xA;DELETE FROM [HealthcareDW].[DimMedicalCondition] WHERE ConditionKey != -1;&#xA;DELETE FROM [HealthcareDW].[DimTestResult] WHERE TestResultKey != -1;&#xA;&#xA;INSERT INTO HealthcareDW.dbo.ETL_LOG (StartTime, TableName, Status)&#xA;VALUES (GETDATE(), 'ETL Initial Load', 'Running');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
