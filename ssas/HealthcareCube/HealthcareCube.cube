  <MdxScripts>
    <MdxScript dwd:design-time-name="6f7e003d-8ed7-44dd-ad7d-84ddc4b9ed88">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;  

CREATE MEMBER CURRENTCUBE.[Measures].[ALOS]
AS
IIF(
    [Measures].[Admission Count] = 0,
    NULL,
    [Measures].[Length Of Stay] / [Measures].[Admission Count]
),
FORMAT_STRING = "0.00";  

CREATE MEMBER CURRENTCUBE.[Measures].[RevenuePerDay]
AS
IIF(
    [Measures].[Length Of Stay] = 0,
    NULL,
    [Measures].[Billing Amount] / [Measures].[Length Of Stay]
),
FORMAT_STRING = "0.00";  

CREATE MEMBER CURRENTCUBE.[Measures].[AbnormalTestRate]
 AS IIF(
    [Measures].[Admission Count] = 0,
    NULL,
    (
        [Measures].[Admission Count],
        [Dim Test Result].[Test Result Name].&amp;[Abnormal]
    ) / [Measures].[Admission Count] * 100
), 
FORMAT_STRING = "0.00", 
VISIBLE = 1  ;  

CREATE MEMBER CURRENTCUBE.[Measures].[EmergencyRate]
 AS IIF(
    [Measures].[Admission Count] = 0,
    NULL,
    (
        [Measures].[Admission Count],
        [Dim Admission Type].[Admission Type Name].&amp;[Emergency]
    ) / [Measures].[Admission Count] * 100
), 
FORMAT_STRING = "0.00", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>